# .env.template — copy to .env and fill in your key.
# .env is gitignored and must NEVER be committed.

# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_key_here

# Optional: model override for extraction (defaults to claude-sonnet-5).
# Uncomment to override, e.g. for maximum vision accuracy on hard drawings:
# EXTRACTION_MODEL=claude-opus-4-8

# Optional (Windows only): path to a blank SolidWorks part template.
# If unset, the SolidWorks default part template is used.
SOLIDWORKS_TEMPLATE_PATH=C:\ProgramData\SolidWorks\SolidWorks 2024\templates\Part.prtdot
