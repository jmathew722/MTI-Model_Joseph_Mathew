# .env.template — copy to .env and fill in your key.
# .env is gitignored and must NEVER be committed.

# Required (default provider — Claude): your Anthropic API key
# (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_key_here

# Optional: model override for extraction (defaults to claude-sonnet-5).
# Uncomment to override, e.g. for maximum vision accuracy on hard drawings:
# EXTRACTION_MODEL=claude-opus-4-8

# --- MTI_Codex branch only: OpenAI provider ---------------------------------
# Set AI_PROVIDER=openai to swap the entire pipeline (extraction, Stage 1.5
# overview analysis, must-meet spec parsing, overview cross-check) from Claude
# to OpenAI's GPT-5.6. Leave both lines below commented/unset to stay on
# Claude (the default on every branch, including main).
# AI_PROVIDER=openai
# OPENAI_API_KEY=your_key_here
# Optional: override the OpenAI model (defaults to gpt-5.6, the frontier tier
# used for every stage). See PRICING in pipeline/usage_log.py for other tiers
# (gpt-5.6-terra, gpt-5.6-luna).
# EXTRACTION_MODEL=gpt-5.6

# Optional (Windows only): path to a blank SolidWorks part template.
# If unset, the SolidWorks default part template is used.
SOLIDWORKS_TEMPLATE_PATH=C:\ProgramData\SolidWorks\SolidWorks 2024\templates\Part.prtdot
